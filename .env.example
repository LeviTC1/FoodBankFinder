# Backend
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodbankfinder
# Single origin, comma-separated list, or *
# Examples:
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://foodbankfinder.vercel.app,https://www.foodbankfinder.org
CORS_ORIGIN=http://localhost:5173
GIVEFOOD_API_URL=https://www.givefood.org.uk/api/2/foodbanks/
TRUSSELL_TRUST_DATA_URL=
IFAN_DATA_URL=
OVERPASS_URL=https://overpass-api.de/api/interpreter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ENRICHMENT_BATCH_SIZE=50
ENRICHMENT_RATE_LIMIT_MS=1000
ENRICHMENT_MIN_CONFIDENCE=0.6

# Frontend (set in frontend/.env)
# VITE_API_BASE_URL=http://localhost:4000
